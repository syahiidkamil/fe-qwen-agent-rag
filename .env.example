# Backend (FastAPI)
VITE_API_URL=http://localhost:3081

# Supabase
# Frontend uses PUBLISHABLE key only. The SECRET key MUST stay on the backend.
# From: Supabase Dashboard -> Settings -> API
#   VITE_SUPABASE_URL              = Project URL
#   VITE_SUPABASE_PUBLISHABLE_KEY  = sb_publishable_...
#
# WARNING: anything VITE_* is shipped in the JS bundle. Never put
# sb_secret_..., DashScope keys, or DB passwords here.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
